# build-time copies of node_modules assets — regenerated by scripts/copy-fonts.mjs
# via the `npm run dev` / `npm run build` hooks. Tracking them would bloat the
# repo and make the `@fontsource/*` + chart.js deps in package.json meaningless.
public/fonts/*.woff2
public/vendor/chart.umd.js

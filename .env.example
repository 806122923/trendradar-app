# ==============================================================
# TrendRadar · Environment Variables
# Copy this file to `.env` and fill in real values.
# DO NOT COMMIT `.env` — it's in .gitignore.
# ==============================================================

# ---- App ----
APP_ENV=development
LOG_LEVEL=INFO
SECRET_KEY=change-me-to-something-random-at-least-32-chars

# ---- Database (Postgres) ----
# Local (via docker-compose):
DATABASE_URL=postgresql+asyncpg://trendradar:trendradar@localhost:5432/trendradar

# Production (Neon — recommended, see DEPLOY.md):
# DATABASE_URL=postgresql+asyncpg://neondb_owner:[PWD]@ep-xxx.us-east-2.aws.neon.tech/neondb?ssl=require

# ---- CORS (production only) ----
# Comma-separated prod origins allowed to call the API. Vercel preview URLs
# (*.vercel.app) are auto-allowed in main.py.
# CORS_ORIGINS=https://trendradar.ai,https://www.trendradar.ai

# ---- Redis ----
REDIS_URL=redis://localhost:6379/0
# Production (Upstash):
# REDIS_URL=rediss://default:[PASSWORD]@[HOST].upstash.io:6379

# ---- LLM providers ----
# Get a key from https://platform.deepseek.com  (cheap, default for free users)
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1

# Get a key from https://console.anthropic.com  (quality, for paid users)
ANTHROPIC_API_KEY=

# Routing: which model tier each plan gets
LLM_FREE_TIER_MODEL=deepseek-chat
LLM_PRO_TIER_MODEL=claude-sonnet-4-6

# ---- Frontend-facing (Next.js) ----
# These are read by the frontend. Prefix with NEXT_PUBLIC_ to expose to browser.
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ---- Auth / OAuth (optional for MVP week 1) ----
# SUPABASE_URL=
# SUPABASE_ANON_KEY=
# SUPABASE_SERVICE_ROLE_KEY=

# ---- Data source (optional week 1) ----
# APIFY_TOKEN=
# APIFY_TIKTOK_ACTOR=apify/tiktok-shop-scraper

# ---- Payments (week 7+) ----
# STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET=

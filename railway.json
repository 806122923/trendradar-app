{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.railway",
    "watchPatterns": [
      "apps/api/**",
      "Dockerfile.railway",
      "railway.json"
    ]
  },
  "deploy": {
    "preDeployCommand": "alembic upgrade head",
    "startCommand": "sh -c 'echo \"Starting TrendRadar API on port ${PORT:-8000}\" && uvicorn app.main:app --host 0.0.0.0 --port ${PORT:-8000} --workers 1 --proxy-headers --forwarded-allow-ips=*'",
    "healthcheckPath": "/api/v1/health",
    "healthcheckTimeout": 120,
    "restartPolicyType": "ON_FAILURE",
    "restartPolicyMaxRetries": 3
  }
}
